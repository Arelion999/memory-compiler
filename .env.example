# memory-compiler env config
# Скопируйте в .env и заполните. .env в .gitignore, не коммитится.

# ─── Безопасность ────────────────────────────────────────────────────────

# API ключ для авторизации (Bearer-заголовок или cookie). Пусто = без авторизации.
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(32))"
MC_API_KEY=

# Ключ шифрования для save_secret (AES-256). Пусто = save_secret недоступен.
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ВАЖНО: MC_ENCRYPT_KEY должен ОТЛИЧАТЬСЯ от MC_API_KEY. API-ключ передаётся в каждом
# запросе; если он равен ключу шифрования, его утечка раскроет все секреты. Сервер
# предупреждает при старте, если ключи совпадают или MC_API_KEY пуст при заданном шифровании.
MC_ENCRYPT_KEY=

# ─── Git Capture ─────────────────────────────────────────────────────────

# Хост-путь с репозиториями, монтируется как /repos:ro в контейнере.
# Нужен только для git_capture(repo_path=...) режима.
# GIT_REPOS_PATH=/home/user/projects

# Разрешённые корни для git_capture (через запятую). Defense-in-depth.
# По умолчанию: /repos
# GIT_CAPTURE_ALLOWED_ROOTS=/repos,/tmp

# ─── ML модели (retrieval pipeline) ──────────────────────────────────────

# Embedding модель для semantic search.
# Default (backward compat): paraphrase-multilingual-MiniLM-L12-v2 (384 dim, MTEB ~50)
# Recommended upgrade: BAAI/bge-m3 (1024 dim, multilingual, MTEB ~63, long context)
# Alt: Alibaba-NLP/gte-multilingual-base
# При смене модели .embeddings.pkl автоматически инвалидируется — нужен reindex.
# EMBED_MODEL=BAAI/bge-m3

# Cross-encoder reranker (применяется в search/get_context/start_task).
# Default: BAAI/bge-reranker-v2-m3 (multilingual, на базе BGE-M3).
# Alt: cross-encoder/ms-marco-MiniLM-L-6-v2 (англоязычный, легче на RAM).
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Late chunking (Jina AI pattern, v1.7.0+): whole-document embedding
# вместо разбиения на ###-секции. Сохраняет контекст между секциями.
# Имеет смысл только с long-context embed модели (BGE-M3 max=8192).
# LATE_CHUNKING=true

# SPLADE 3-way hybrid (BM25 + dense + sparse-learned). Skeleton в v1.7.0,
# реальная модель пока не подключена — graceful fallback на 2-way hybrid.
# SPLADE_ENABLED=false

# Memory-safe encoding (v1.7.1+) — peak allocation control при batch encode.
# EMBED_BATCH_SIZE=8         # default 8, увеличь до 16-32 если RAM в избытке
# EMBED_MAX_SEQ_LENGTH=2048  # cap для long-context моделей (BGE-M3 default=8192)

# HF Hub offline-режим (default 1) — после первой загрузки модели не делать
# сетевых вызовов к huggingface.co. Решает Errno 99 на сетях с rate-limit/firewall.
# Перед первой загрузкой новой модели временно поставь 0.
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# ─── Timezone ────────────────────────────────────────────────────────────

# Настраивается в docker-compose.yml через TZ env
