# memory-compiler env config
# Скопируйте в .env и заполните. .env в .gitignore, не коммитится.

# ─── Безопасность ────────────────────────────────────────────────────────

# API ключ для авторизации (Bearer / cookie / ?key=). Пусто = без авторизации.
MC_API_KEY=

# Ключ шифрования для save_secret (AES-256). Пусто = save_secret недоступен.
# Используйте сильный ключ: python -c "import secrets; print(secrets.token_urlsafe(32))"
MC_ENCRYPT_KEY=

# ─── Git Capture ─────────────────────────────────────────────────────────

# Хост-путь с репозиториями, монтируется как /repos:ro в контейнере.
# Нужен только для git_capture(repo_path=...) режима.
# GIT_REPOS_PATH=/home/user/projects

# Разрешённые корни для git_capture (через запятую). Defense-in-depth.
# По умолчанию: /repos
# GIT_CAPTURE_ALLOWED_ROOTS=/repos,/tmp

# ─── Timezone ────────────────────────────────────────────────────────────

# Настраивается в docker-compose.yml через TZ env
